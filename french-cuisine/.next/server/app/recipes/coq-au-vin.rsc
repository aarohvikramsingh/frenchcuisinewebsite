5:["$","$L10",null,{"recipe":{"id":"coq-au-vin","name":"Coq au Vin","description":"A classic French dish of chicken braised with wine, mushrooms, and bacon. Perfect for special occasions.","image":"https://images.unsplash.com/photo-1600891964092-4316c288032e?w=800&q=80","prepTime":"2 hours","servings":"4-6","difficulty":"Medium","ingredients":["1 whole chicken, cut into pieces","750ml red wine (Burgundy)","200g bacon lardons","250g mushrooms","12 pearl onions","3 cloves garlic","2 tablespoons flour","Fresh thyme and bay leaf","Butter and olive oil","Salt and pepper"],"steps":["Marinate chicken in wine overnight (optional but recommended).","Brown bacon in a large pot, then remove and set aside.","Brown chicken pieces in bacon fat, then remove.","Sauté onions and mushrooms until golden.","Add garlic and flour, cook for 1 minute.","Return chicken and bacon to pot, add wine and herbs.","Simmer covered for 1.5 hours until chicken is tender.","Serve hot with crusty bread or potatoes."],"region":"Burgundy"}}]
